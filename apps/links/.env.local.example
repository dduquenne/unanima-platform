# =============================================================================
# Link's Accompagnement — Variables d'environnement
# =============================================================================
#
# Usage :
#   cp .env.local.example .env.local
#   # Renseigner les valeurs depuis le dashboard Supabase et Resend
#
# Chaque app utilise son propre projet Supabase.
# Les clés ci-dessous sont spécifiques à l'instance Link's.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Projet Link's Accompagnement
# Dashboard : https://supabase.com/dashboard/project/<project-id>/settings/api
# -----------------------------------------------------------------------------

# URL du projet Supabase (publique, exposée côté client)
NEXT_PUBLIC_SUPABASE_URL=https://your-links-project-id.supabase.co

# Clé anonyme Supabase (publique, exposée côté client, soumise aux RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role Supabase (SECRÈTE — accès admin, contourne les RLS)
# Utilisée uniquement côté serveur (API routes, middleware)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Resend — E-mail transactionnel
# Dashboard : https://resend.com/api-keys
# -----------------------------------------------------------------------------

# Clé API Resend (SECRÈTE — utilisée uniquement côté serveur)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse email expéditeur (optionnel, défaut : Unanima <noreply@unanima.fr>)
EMAIL_FROM="Link's Accompagnement <noreply@links-accompagnement.fr>"

# -----------------------------------------------------------------------------
# Mode Simulation — Données fictives (sans Supabase)
# Mettre à "true" pour afficher l'app avec des données fictives.
# Aucun appel Supabase ne sera effectué. Idéal pour les démos.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SIMULATION_MODE=false
