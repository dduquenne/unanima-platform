# =============================================================================
# Unanima Platform — Variables d'environnement (racine monorepo)
# =============================================================================
#
# Ce fichier sert de référence pour les variables communes.
# Chaque application (apps/links, apps/creai, apps/omega) possède son propre
# fichier .env.local.example avec ses variables spécifiques.
#
# Usage :
#   cp .env.local.example .env.local
#   # Renseigner les valeurs depuis le dashboard Supabase et Resend
#
# IMPORTANT : Ne jamais commiter .env.local — il est ignoré par .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Base de données et authentification
# Dashboard : https://supabase.com/dashboard/project/<project-id>/settings/api
# -----------------------------------------------------------------------------

# URL du projet Supabase (publique, exposée côté client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Clé anonyme Supabase (publique, exposée côté client, soumise aux RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role Supabase (SECRÈTE — accès admin, contourne les RLS)
# Utilisée uniquement côté serveur (API routes, middleware)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Resend — E-mail transactionnel
# Dashboard : https://resend.com/api-keys
# -----------------------------------------------------------------------------

# Clé API Resend (SECRÈTE — utilisée uniquement côté serveur)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
